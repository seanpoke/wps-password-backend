# 生产环境配置文件
# 将此文件放在 config/ 目录下，命名为 application-prod.yml

spring:
  datasource:
    # 使用环境变量 BUSI_OUTER_IP，在 docker-compose 中设置为 mysql8（容器服务名）
    url: jdbc:mysql://${busi.outer-ip}:3306/doc_auth_system?useUnicode=true&characterEncoding=utf-8&connectionCollation=utf8mb4_unicode_ci&useSSL=false&serverTimezone=Asia/Shanghai&maxAllowedPacket=10485760
    username: ${MYSQL_USER:testuser}
    password: ${MYSQL_PASSWORD:test123456}
    driver-class-name: com.mysql.cj.jdbc.Driver

  data:
    redis:
      host: ${REDIS_HOST:redis}
      port: 6379
      password: ${REDIS_PASSWORD:sean1234}
      database: 0

# 业务配置
busi:
  outer-ip: ${BUSI_OUTER_IP:mysql8}  # 默认值为 mysql8（Docker 服务名）

# 服务器配置
server:
  port: 8081

# Swagger 配置（生产环境建议关闭）
springdoc:
  api-docs:
    enabled: true  # 如需关闭改为 false
  swagger-ui:
    enabled: true  # 如需关闭改为 false

# 日志配置（生产环境）
logging:
  level:
    # 业务日志调整为INFO，减少日志量
    com.docauth: INFO
    # 关闭SQL日志，提高性能
    org.hibernate.SQL: WARN
    org.hibernate.type.descriptor.sql.BasicBinder: WARN
