<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds" debug="false">
    
    <!-- 定义日志文件存储路径 -->
    <property name="LOG_HOME" value="./logs"/>
    <!-- 定义应用名称 -->
    <property name="APP_NAME" value="wps-password-backend"/>
    <!-- 定义密码审计日志存储路径 -->
    <property name="PASSWORD_LOG_HOME" value="./passwordLog"/>
    
    <!-- 控制台输出配置 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 格式化输出：%d表示日期，%thread表示线程名，%-5level：级别从左显示5个字符宽度，%logger表示类名，%msg：日志消息，%n是换行符 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 所有日志文件输出 -->
    <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-all.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 滚动策略：按时间滚动 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 每天生成一个日志文件 -->
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-all.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 保留15天的日志 -->
            <maxHistory>15</maxHistory>
            <!-- 所有日志文件总大小上限10GB -->
            <totalSizeCap>20GB</totalSizeCap>
        </rollingPolicy>
    </appender>
    
    <!-- INFO级别日志文件输出 -->
    <appender name="FILE_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-info.log</file>
        <!-- 只记录INFO及以上级别的日志 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>
    
    <!-- WARN级别日志文件输出 -->
    <appender name="FILE_WARN" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-warn.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-warn.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>
    
    <!-- ERROR级别日志文件输出 -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>
    
    <!-- 密码审计日志专用Appender - 异步非阻塞 -->
    <appender name="PASSWORD_AUDIT_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${PASSWORD_LOG_HOME}/password_audit.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 添加毫秒级时间戳，符合等保合规标准 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} | %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 按月滚动策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 按月生成日志文件，格式：yyyy_MM.log（修正：移除 , aux，使用标准月份推导语法） -->
            <fileNamePattern>${PASSWORD_LOG_HOME}/%d{yyyy_MM}.log</fileNamePattern>
            <!-- 保留12个月的日志 -->
            <maxHistory>12</maxHistory>
            <!-- 所有密码审计日志文件总大小上限50GB -->
            <totalSizeCap>50GB</totalSizeCap>
        </rollingPolicy>
        <!-- 立即刷新到磁盘 -->
        <immediateFlush>true</immediateFlush>
    </appender>
    
    <!-- 密码审计日志异步包装器（自定义环形队列） -->
    <appender name="ASYNC_PASSWORD_AUDIT_APPENDER" class="com.docauth.config.RingBufferAsyncAppender">
        <!-- 队列容量 -->
        <queueSize>50000</queueSize>
        <!-- 必须设置为 true，确保 Logback 调用 queue.offer() 而非 put() -->
        <!-- 这样才能触发我们重写的 offer() 方法中的环形队列逻辑 -->
        <neverBlock>true</neverBlock>
        <!-- 引用实际的密码审计日志 appender -->
        <appender-ref ref="PASSWORD_AUDIT_APPENDER"/>
    </appender>
    
    <!-- 密码审计日志专用Logger -->
    <logger name="PASSWORD_AUDIT_LOGGER" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_PASSWORD_AUDIT_APPENDER"/>
    </logger>
    
    <!-- Spring框架日志 -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.boot" level="INFO"/>
    
    <!-- Hibernate/JPA日志 - 基础配置 -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>
    
    <!-- MySQL驱动日志 -->
    <logger name="com.mysql" level="WARN"/>
    
    <!-- Redis日志 -->
    <logger name="org.springframework.data.redis" level="INFO"/>
    
    <!-- Root Logger配置 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_ALL"/>
        <appender-ref ref="FILE_INFO"/>
        <appender-ref ref="FILE_WARN"/>
        <appender-ref ref="FILE_ERROR"/>
    </root>
    
    <!-- 优雅停机配置 -->
    <shutdownHook class="ch.qos.logback.core.hook.DelayingShutdownHook"/>
    
    <!-- 开发环境日志级别 -->
    <springProfile name="dev">
        <logger name="com.docauth" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
    </springProfile>
    
    <!-- 生产环境日志级别 -->
    <springProfile name="prod">
        <logger name="com.docauth" level="INFO"/>
        <logger name="org.hibernate.SQL" level="INFO"/>
    </springProfile>
    
</configuration>
